# ============================================================
# GawdBotE — Environment Configuration
# Copy to .env and fill in your values
# ============================================================

# ---- LLM Providers ----
ANTHROPIC_API_KEY=              # Required: get from console.anthropic.com
OPENROUTER_API_KEY=             # Optional: fallback LLM provider
OPENAI_API_KEY=                 # Optional: for embeddings + GPT-4V vision

# LLM model selection
CLAUDE_SMART_MODEL=claude-sonnet-4-6    # For reasoning/responses
CLAUDE_FAST_MODEL=claude-haiku-4-5-20251001   # For intent routing

# ---- Memory / Database ----
SUPABASE_URL=                   # From Supabase project settings
SUPABASE_ANON_KEY=              # From Supabase project settings
# Leave blank to use SQLite fallback
SQLITE_PATH=~/.gawdbote/memory.db

# ---- User Profile ----
USER_NAME=                      # Your first name
USER_TIMEZONE=America/New_York  # Your timezone (TZ database name)

# ---- Interfaces ----
# Telegram
TELEGRAM_BOT_TOKEN=             # From @BotFather
TELEGRAM_USER_ID=               # Your Telegram user ID (from @userinfobot)

# Discord (optional)
DISCORD_BOT_TOKEN=
DISCORD_GUILD_ID=
DISCORD_USER_ID=

# ---- Voice (optional) ----
# Provider: "groq", "local", or "elevenlabs"
VOICE_STT_PROVIDER=groq         # Speech-to-text
VOICE_TTS_PROVIDER=piper        # Text-to-speech
GROQ_API_KEY=                   # For Groq STT (free tier available)
ELEVENLABS_API_KEY=             # For ElevenLabs TTS
ELEVENLABS_VOICE_ID=            # Preferred voice ID
WHISPER_MODEL=base.en           # Local whisper model size
PIPER_MODEL=en_US-lessac-medium # Local TTS voice
WAKE_WORD=hey_gawd              # Custom wake word (openwakeword)

# ---- Vision ----
VISION_PROVIDER=claude          # "claude" or "openai"

# ---- Device Control ----
DEVICE_CONTROL_ENABLED=false    # Enable mouse/keyboard control
BROWSER_HEADLESS=true           # Run Playwright headless

# ---- Services ----
BACKEND_PORT=8000
FRONTEND_PORT=3000
LOG_LEVEL=info

# ---- Self-Improvement ----
GITHUB_TOKEN=                   # For /evolve PR creation
GITHUB_REPO=                    # owner/repo for PRs
